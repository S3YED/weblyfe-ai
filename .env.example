# Instant Appie BETA - environment variables
# Copy to .env.local for development. Do not commit values; only names.
# Production values live in Vercel env (per Stripe handling mandates v2).

# Postgres connection. Local dev: docker-compose.dev.yml exposes one on port 5433.
DATABASE_URL=

# 32+ byte secret for session JWTs. App refuses to boot if missing or under 32 bytes.
JWT_SECRET=

# 32-byte hex (64 chars) key for libsodium secretbox. Never commit.
SECRETBOX_KEY=

# Stripe TEST keys for dev/preview. Never put live keys here.
# STRIPE_LIVE_OK approval phrase required to swap to live in production.
STRIPE_SECRET_KEY_TEST=
STRIPE_WEBHOOK_SECRET_TEST=

# Brevo Transactional Email
BREVO_API_KEY=
BREVO_BETA_LIST_ID=19

# Telegram bot pool (5 stub tokens, comma-separated)
TELEGRAM_BOT_TOKEN_POOL=
# Optional: ops-bot for first-ping forwarding in staging
TELEGRAM_OPS_BOT_TOKEN=
TELEGRAM_OPS_CHAT_ID=

# Google OAuth - calendar.events scope only (gmail deferred per PRD)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Hetzner Cloud API key. PRODUCTION ONLY. Set PROVISION_MODE=real to enable.
# Requires STRIPE_LIVE_OK: provision_real_servers approval before enabling.
HETZNER_API_KEY=
PROVISION_MODE=mock

# Public app URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: dev autocreate users on /appie/auth/request-link (set to 1 to enable)
APPIE_AUTOCREATE_ON_REQUEST=
