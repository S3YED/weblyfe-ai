  "usps": {
    "philosophy": "Focus on measurable results, not features",
    "examples": {
      "good": ["95% faster", "40% more leads", "99% response improvement", "15+ hrs/week saved"],
      "bad": ["50+ voice notes used", "Built in 1 day", "Real-time revisions"]
    },
    "rule": "Every stat should answer: 'What business outcome did this deliver?'"
  },

  "content_requirements": {
    "case_studies": {
      "required_fields": [
        "title",
        "subtitle",
        "description",
        "fullDescription",
        "image",
        "stats (3, with measurable outcomes)",
        "tech",
        "quote",
        "author",
        "challenge",
        "solution",
        "results (5 bullet points)"
      ],
      "optional_fields": [
        "mobileImage",
        "gallery",
        "projectUrl",
        "weblyfeUrl"
      ]
    }
  },

  "deployment": {
    "platform": "Vercel",
    "branch": "main",
